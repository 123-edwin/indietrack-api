// =======================
// DATASOURCE && GENERATOR
// =======================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =======================
// ENUMS
// =======================

enum ProjectType {
  SINGLE
  EP
  ALBUM
}

// =======================
// MODELS
// =======================

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  projects      Project[]
  collaborators Collaborator[]

  @@map("users")
}

model Project {
  id          String      @id @default(uuid())
  name        String
  description String?
  type        ProjectType

  coverImageUrl String?
  coverImageKey String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tracks Track[]

  // audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  updatedBy String?

  // soft delete
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, deletedAt])
  @@map("projects")
}

model Track {
  id         String  @id @default(uuid())
  title      String
  bpm        Int?
  musicalKey String?
  duration   Int?

  audioUrl String?
  audioKey String?

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  collaborators Collaborator[]

  // audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  updatedBy String?

  // soft delete
  deletedAt DateTime?

  @@index([projectId])
  @@index([projectId, deletedAt])
  @@map("tracks")
}

model Collaborator {
  id   String @id @default(uuid())
  name String
  role String

  trackId String
  track   Track  @relation(fields: [trackId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trackId])
  @@index([userId])
  @@map("collaborators")
}
